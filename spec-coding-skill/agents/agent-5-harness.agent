### 4. Harness Runner (scripts/run_harness.py)

```python
#!/usr/bin/env python3
"""
Execute the harness verification pipeline.
"""

import yaml
import subprocess
import sys
from pathlib import Path

def load_harness():
    """Load harness configuration."""
    with open("harness.yaml") as f:
        return yaml.safe_load(f)

def run_step(step):
    """Execute a single verification step."""
    print(f"Running: {step['name']}")
    result = subprocess.run(
        step['command'],
        shell=True,
        capture_output=True,
        timeout=step.get('timeout', 60)
    )
    return result.returncode == 0

def main():
    harness = load_harness()
    
    for step in harness['harness']['verification']['steps']:
        success = run_step(step)
        if not success and step.get('must_pass', False):
            print(f"FAILED: {step['name']}")
            return 1
    
    print("All checks passed!")
    return 0

if __name__ == "__main__":
    sys.exit(main())
```

## Guidelines
- Make verification steps incremental (fail fast)
- Set realistic timeouts
- Balance thoroughness with execution time
- Ensure traceability checks are automated
- Document all quality gates clearly

