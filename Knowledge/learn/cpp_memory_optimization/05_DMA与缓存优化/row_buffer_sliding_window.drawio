          <mxGeometry y="140" width="290" height="20" as="geometry" />
        </mxCell>
        <mxCell id="row-n" value="Row N: ████████" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontFamily=monospace;" parent="pixel-grid" vertex="1">
          <mxGeometry y="160" width="290" height="20" as="geometry" />
