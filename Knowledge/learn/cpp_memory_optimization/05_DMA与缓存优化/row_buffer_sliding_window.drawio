        <mxCell id="row6" value="Row 6: ████████" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontFamily=monospace;" parent="pixel-grid" vertex="1">
