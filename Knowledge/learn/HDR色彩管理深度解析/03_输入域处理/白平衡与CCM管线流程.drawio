<mxfile host="app.diagrams.net" agent="draw.io" version="24.0.0">
  <diagram name="白平衡与CCM管线流程" id="wb-ccm-pipeline">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ========== 标题 ========== -->
        <mxCell id="title" value="&lt;font style=&quot;font-size:24px;&quot;&gt;&lt;b&gt;白平衡与色彩校正矩阵（CCM）管线流程&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:13px;color:#888888;&quot;&gt;ISP 色彩处理核心链路：粗校正（Bayer域） → 精校正（RGB域）&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="420" y="15" width="560" height="55" as="geometry"/>
        </mxCell>

        <!-- ========== 第一部分：ISP 完整管线总览 ========== -->
        <mxCell id="pipeline_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#dddddd;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="85" width="1340" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="pipeline_label" value="&lt;b&gt;ISP 色彩处理管线总览&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="55" y="92" width="170" height="25" as="geometry"/>
        </mxCell>

        <!-- 管线节点 -->
        <mxCell id="p1" value="&lt;b&gt;传感器&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;RAW 输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="55" y="125" width="95" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;BLC&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;黑电平校正&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="185" y="125" width="95" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;DPC&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;坏点校正&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="315" y="125" width="95" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;LSC&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;镜头阴影校正&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="445" y="125" width="95" height="50" as="geometry"/>
        </mxCell>

        <!-- WB 高亮 -->
        <mxCell id="p5" value="&lt;b&gt;AWB&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;白平衡校正&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="575" y="125" width="95" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="p6" value="&lt;b&gt;Demosaic&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;去马赛克&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6e6e6;strokeColor=#999999;fontSize=12;arcSize=15;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="705" y="125" width="95" height="50" as="geometry"/>
        </mxCell>

        <!-- CCM 高亮 -->
        <mxCell id="p7" value="&lt;b&gt;CCM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;色彩校正矩阵&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=15;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="835" y="125" width="95" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="p8" value="&lt;b&gt;Gamma&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;色调映射&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="965" y="125" width="95" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="p9" value="&lt;b&gt;sRGB&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;最终输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="1095" y="125" width="95" height="50" as="geometry"/>
        </mxCell>

        <!-- 管线箭头 -->
        <mxCell id="a12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.5;strokeColor=#999999;" edge="1" source="p1" target="p2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.5;strokeColor=#999999;" edge="1" source="p2" target="p3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.5;strokeColor=#999999;" edge="1" source="p3" target="p4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a45" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d6b656;" edge="1" source="p4" target="p5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a56" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#999999;" edge="1" source="p5" target="p6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a67" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="p6" target="p7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a78" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.5;strokeColor=#999999;" edge="1" source="p7" target="p8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a89" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.5;strokeColor=#999999;" edge="1" source="p8" target="p9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 域标注 -->
        <mxCell id="domain_bayer" value="&lt;font color=&quot;#d6b656&quot;&gt;◼&lt;/font&gt; &lt;b&gt;Bayer 域&lt;/b&gt;（单通道，每像素1次乘法）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="200" y="185" width="290" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="domain_rgb" value="&lt;font color=&quot;#6c8ebf&quot;&gt;◼&lt;/font&gt; &lt;b&gt;RGB 域&lt;/b&gt;（三通道，3×3矩阵运算）" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="810" y="185" width="280" height="20" as="geometry"/>
        </mxCell>

        <!-- 分界线 -->
        <mxCell id="divider" style="endArrow=none;html=1;strokeColor=#cccccc;strokeWidth=1;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="752" y="120" as="sourcePoint"/>
            <mxPoint x="752" y="205" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="divider_label" value="&lt;font color=&quot;#aaaaaa&quot;&gt;域切换&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="100" width="55" height="20" as="geometry"/>
        </mxCell>

        <!-- ========== 第二部分：白平衡详细流程（左侧） ========== -->
        <mxCell id="wb_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffef0;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="640" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="wb_title" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;白平衡校正（AWB）&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#888888;&quot;&gt;粗校正 · Bayer 域 · 对角线增益模型&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="220" y="252" width="240" height="40" as="geometry"/>
        </mxCell>

        <!-- 输入 -->
        <mxCell id="wb_input" value="&lt;b&gt;Bayer RAW 数据&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;已完成 BLC/DPC/LSC&lt;br&gt;R/G/B 通道比例失调&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="65" y="310" width="175" height="60" as="geometry"/>
        </mxCell>

        <!-- AWB 光源估计 -->
        <mxCell id="wb_estimate" value="&lt;b&gt;光源色温估计&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666;&quot;&gt;灰度世界 / 白点检测&lt;br&gt;/ 学习模型&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="65" y="415" width="175" height="60" as="geometry"/>
        </mxCell>

        <!-- 增益计算 -->
        <mxCell id="wb_gain" value="&lt;b&gt;计算通道增益&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666;&quot;&gt;g_r = G_mean / R_mean&lt;br&gt;g_b = G_mean / B_mean&lt;br&gt;g_g = 1（基准）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="65" y="520" width="175" height="75" as="geometry"/>
        </mxCell>

        <!-- 增益应用 -->
        <mxCell id="wb_apply" value="&lt;b&gt;对角线增益应用&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#333;&quot;&gt;R_wb = g_r × R_raw&lt;br&gt;G_wb = 1.0 × G_raw&lt;br&gt;B_wb = g_b × B_raw&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="65" y="640" width="175" height="75" as="geometry"/>
        </mxCell>

        <!-- 输出 -->
        <mxCell id="wb_output" value="&lt;b&gt;白平衡后 Bayer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;中性色接近 R≈G≈B&lt;br&gt;全局色偏已消除&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="65" y="755" width="175" height="55" as="geometry" />
        </mxCell>

        <!-- 左侧流程箭头 -->
        <mxCell id="wb_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d6b656;" edge="1" source="wb_input" target="wb_estimate" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wb_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d6b656;" edge="1" source="wb_estimate" target="wb_gain" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wb_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#d6b656;" edge="1" source="wb_gain" target="wb_apply" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="wb_a4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#82b366;" edge="1" source="wb_apply" target="wb_output" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 右侧：色温场景示例 -->
        <mxCell id="scene_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefefe;strokeColor=#dddddd;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="310" width="350" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="scene_title" value="&lt;b&gt;不同色温下的增益变化&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="390" y="318" width="170" height="22" as="geometry"/>
        </mxCell>

        <!-- 暖光 -->
        <mxCell id="s1_color" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9966;strokeColor=#CC6633;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="330" y="355" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s1_text" value="&lt;b&gt;2700K 暖光&lt;/b&gt;：偏红橙" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="370" y="355" width="140" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="s1_gain" value="g_r=0.7 &lt;font color=&quot;#888&quot;&gt;↓&lt;/font&gt;　g_b=1.8 &lt;font color=&quot;#888&quot;&gt;↑&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="370" y="375" width="170" height="20" as="geometry"/>
        </mxCell>

        <!-- 日光 -->
        <mxCell id="s2_color" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFEE;strokeColor=#CCCCAA;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="330" y="410" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s2_text" value="&lt;b&gt;6500K 日光&lt;/b&gt;：接近中性" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="370" y="410" width="155" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="s2_gain" value="g_r≈1.0　g_b≈1.0 &lt;font color=&quot;#888&quot;&gt;几乎无校正&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="370" y="430" width="260" height="20" as="geometry"/>
        </mxCell>

        <!-- 阴影 -->
        <mxCell id="s3_color" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#99BBEE;strokeColor=#6688BB;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="330" y="465" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s3_text" value="&lt;b&gt;8000K 阴影&lt;/b&gt;：偏蓝" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="370" y="465" width="140" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="s3_gain" value="g_r=1.6 &lt;font color=&quot;#888&quot;&gt;↑&lt;/font&gt;　g_b=0.6 &lt;font color=&quot;#888&quot;&gt;↓&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="370" y="485" width="170" height="20" as="geometry"/>
        </mxCell>

        <!-- 目标白点说明 -->
        <mxCell id="target_note" value="&lt;font color=&quot;#555555&quot;&gt;所有场景 →&lt;/font&gt; &lt;b&gt;目标白点固定 D65&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;(x=0.3127, y=0.3290, 6504K)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="530" width="230" height="40" as="geometry"/>
        </mxCell>

        <!-- 白平衡特性说明 -->
        <mxCell id="wb_char_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefefe;strokeColor=#dddddd;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="590" width="350" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="wb_char_title" value="&lt;b&gt;白平衡关键特性&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="405" y="600" width="120" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="wb_c1" value="✅ 在 Bayer 域执行（Demosaic 之前）" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="630" width="250" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="wb_c2" value="✅ 对角线增益，每像素仅 1 次乘法" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="655" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="wb_c3" value="✅ 消除全局色偏，让中性色 R≈G≈B" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="680" width="270" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="wb_c4" value="⚠️ 无法校正通道间耦合误差" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="330" y="705" width="220" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="wb_c5" value="⚠️ 传感器光谱响应≠标准观察者响应" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="330" y="730" width="280" height="20" as="geometry"/>
        </mxCell>

        <!-- ========== 中间连接：WB → Demosaic → CCM ========== -->
        <mxCell id="mid_arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=3;strokeColor=#82b366;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="660" y="782" as="sourcePoint"/>
            <mxPoint x="720" y="782" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- Demosaic 中间节点 -->
        <mxCell id="mid_demosaic" value="&lt;b&gt;Demosaic&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;Bayer → RGB&lt;br&gt;单通道 → 三通道&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6e6e6;strokeColor=#999999;fontSize=12;arcSize=15;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="755" width="155" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="mid_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#999999;" edge="1" source="wb_output" target="mid_demosaic" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 长箭头到 CCM -->
        <mxCell id="mid_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="mid_demosaic" target="ccm_input" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- ========== 第三部分：CCM 详细流程（右侧） ========== -->
        <mxCell id="ccm_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f5ff;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="720" y="240" width="620" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="ccm_title" value="&lt;font style=&quot;font-size:16px;&quot;&gt;&lt;b&gt;色彩校正矩阵（CCM）&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#888888;&quot;&gt;精校正 · RGB 域 · 3×3 全矩阵运算&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="880" y="252" width="270" height="40" as="geometry"/>
        </mxCell>

        <!-- CCM 输入 -->
        <mxCell id="ccm_input" value="&lt;b&gt;Demosaic 后 RGB&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;白平衡已校正&lt;br&gt;但仍为传感器色彩空间&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="310" width="190" height="60" as="geometry"/>
        </mxCell>

        <!-- 标定 -->
        <mxCell id="ccm_calib" value="&lt;b&gt;ColorChecker 标定&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666;&quot;&gt;拍摄24色/140色标准色卡&lt;br&gt;记录传感器RGB与标准Lab值&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="415" width="190" height="65" as="geometry"/>
        </mxCell>

        <!-- 矩阵求解 -->
        <mxCell id="ccm_solve" value="&lt;b&gt;最小二乘求解 3×3 矩阵&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666;&quot;&gt;M = target × pinv(sensor)&lt;br&gt;约束每行之和 = 1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="525" width="190" height="65" as="geometry"/>
        </mxCell>

        <!-- 矩阵应用 -->
        <mxCell id="ccm_apply" value="&lt;b&gt;3×3 矩阵乘法&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#333;&quot;&gt;[R G B]_out = M × [R G B]_in&lt;br&gt;校正通道间耦合&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=15;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="745" y="640" width="190" height="60" as="geometry"/>
        </mxCell>

        <!-- 输出 -->
        <mxCell id="ccm_output" value="&lt;b&gt;标准 sRGB 色彩&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#888;&quot;&gt;色彩精确映射到&lt;br&gt;目标色彩空间（D65白点）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="745" y="745" width="190" height="55" as="geometry"/>
        </mxCell>

        <!-- CCM 流程箭头 -->
        <mxCell id="ccm_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="ccm_input" target="ccm_calib" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ccm_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="ccm_calib" target="ccm_solve" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ccm_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="ccm_solve" target="ccm_apply" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ccm_a4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#82b366;" edge="1" source="ccm_apply" target="ccm_output" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- 右侧：CCM 矩阵结构展示 -->
        <mxCell id="matrix_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefefe;strokeColor=#dddddd;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="310" width="340" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="matrix_title" value="&lt;b&gt;典型 CCM 矩阵结构&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1070" y="320" width="150" height="22" as="geometry"/>
        </mxCell>

        <!-- 矩阵 3x3 -->
        <mxCell id="m00" value="&lt;b&gt;1.2&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1020" y="355" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m01" value="-0.1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=14;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1080" y="355" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m02" value="-0.1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=14;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1140" y="355" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m10" value="-0.1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=14;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1020" y="395" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m11" value="&lt;b&gt;1.1&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1080" y="395" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m12" value="-0.0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=14;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1140" y="395" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m20" value="-0.0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=14;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1020" y="435" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m21" value="-0.2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=14;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="1080" y="435" width="60" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="m22" value="&lt;b&gt;1.2&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1140" y="435" width="60" height="40" as="geometry"/>
        </mxCell>

        <!-- 矩阵说明 -->
        <mxCell id="m_diag" value="&lt;font color=&quot;#333&quot;&gt;&lt;b&gt;对角线&lt;/b&gt;&lt;/font&gt;：通道增强/减弱" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1215" y="390" width="180" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m_off" value="&lt;font color=&quot;#888&quot;&gt;&lt;b&gt;非对角线&lt;/b&gt;&lt;/font&gt;：通道间串扰校正" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1215" y="415" width="200" height="20" as="geometry"/>
        </mxCell>

        <!-- CCM 特性说明 -->
        <mxCell id="ccm_char_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefefe;strokeColor=#dddddd;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="530" width="340" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="ccm_char_title" value="&lt;b&gt;CCM 关键特性&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1080" y="540" width="110" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="ccm_c1" value="✅ 在 RGB 域执行（Demosaic 之后）" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1000" y="575" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="ccm_c2" value="✅ 3×3 全矩阵，校正通道间耦合" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1000" y="600" width="250" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="ccm_c3" value="✅ 精确映射到 sRGB/Rec.709 标准" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1000" y="625" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="ccm_c4" value="✅ 修正 WB 对角线模型的残余误差" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1000" y="650" width="270" height="20" as="geometry"/>
        </mxCell>

        <!-- 协作关系总结 -->
        <mxCell id="summary_line" style="endArrow=none;html=1;strokeColor=#cccccc;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1000" y="690" as="sourcePoint"/>
            <mxPoint x="1300" y="690" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="ccm_summary" value="&lt;b&gt;WB + CCM 两级配合&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;白平衡做&lt;font color=&quot;#d6b656&quot;&gt;粗校正&lt;/font&gt;（快速，消除色偏）&lt;br&gt;CCM 做&lt;font color=&quot;#6c8ebf&quot;&gt;精校正&lt;/font&gt;（精确，映射色彩空间）&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="1040" y="700" width="240" height="55" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
