  <diagram name="Demosaic双线性插值" id="demosaic-bilinear">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ========== 标题 ========== -->
        <mxCell id="title" value="&lt;font style=&quot;font-size:24px;&quot;&gt;&lt;b&gt;Demosaic 双线性插值原理&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:14px;color:#666666;&quot;&gt;从 Bayer 单通道马赛克恢复 RGB 三通道图像&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="440" y="20" width="420" height="60" as="geometry"/>
        </mxCell>

        <!-- ========== 顶部总流程 ========== -->
        <!-- Bayer输入框 -->
        <mxCell id="flow_input" value="&lt;b&gt;Bayer RAW&lt;/b&gt;&lt;br&gt;每像素仅1个颜色通道" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="140" y="100" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- 处理框 -->
        <mxCell id="flow_process" value="&lt;b&gt;双线性插值&lt;/b&gt;&lt;br&gt;对缺失通道取邻域均值" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="540" y="100" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- 输出框 -->
        <mxCell id="flow_output" value="&lt;b&gt;完整 RGB&lt;/b&gt;&lt;br&gt;每像素具有R、G、B三通道" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="960" y="100" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- 流程箭头 -->
