          <mxGeometry x="40" y="580" width="740" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="case3_title" value="&lt;b&gt;情况三：在 G 位置插值 R 或 B 通道&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;根据所在行列方向，取水平或垂直两邻域均值&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="200" y="590" width="340" height="45" as="geometry"/>
        </mxCell>

        <!-- 子情况A：G在R行，插值R（水平） -->
        <mxCell id="c3a_label" value="&lt;b&gt;G 在 R 行：水平插值 R&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="80" y="645" width="180" height="25" as="geometry"/>
        </mxCell>

        <!-- 1x3 横向: R0 G(target) R1 -->
        <mxCell id="c3a_0" value="&lt;b&gt;R₀&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="80" y="680" width="65" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="c3a_1" value="&lt;b&gt;G&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#82b366;&quot;&gt;目标&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontColor=#82b366;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="145" y="680" width="65" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="c3a_2" value="&lt;b&gt;R₁&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="210" y="680" width="65" height="55" as="geometry"/>
        </mxCell>

        <!-- 箭头 -->
        <mxCell id="c3a_arrow_l" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="c3a_0" target="c3a_1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c3a_arrow_r" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="c3a_2" target="c3a_1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c3a_formula" value="&lt;b&gt;R = (R₀ + R₁) / 2&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#ae4132;" vertex="1" parent="1">
          <mxGeometry x="95" y="745" width="160" height="25" as="geometry"/>
        </mxCell>

        <!-- 子情况B：G在B行，插值B（水平） -->
        <mxCell id="c3b_label" value="&lt;b&gt;G 在 B 列：垂直插值 B&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="460" y="645" width="180" height="25" as="geometry"/>
        </mxCell>

        <!-- 3x1 纵向: B0 / G(target) / B1 -->
        <mxCell id="c3b_0" value="&lt;b&gt;B₀&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="510" y="675" width="65" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="c3b_1" value="&lt;b&gt;G&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#82b366;&quot;&gt;目标&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontColor=#82b366;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="510" y="725" width="65" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="c3b_2" value="&lt;b&gt;B₁&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="510" y="775" width="65" height="50" as="geometry"/>
        </mxCell>

        <!-- 箭头 -->
        <mxCell id="c3b_arrow_t" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="c3b_0" target="c3b_1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c3b_arrow_b" style="endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="c3b_2" target="c3b_1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="c3b_formula" value="&lt;b&gt;B = (B₀ + B₁) / 2&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontColor=#336699;" vertex="1" parent="1">
          <mxGeometry x="480" y="835" width="155" height="25" as="geometry"/>
        </mxCell>

        <!-- 情况三说明 -->
        <mxCell id="c3_note" value="&lt;font color=&quot;#888888&quot;&gt;G 位置同时需要插值 R 和 B 两个通道，方向取决于该 G 相邻的同色像素排列&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="870" width="520" height="20" as="geometry"/>
        </mxCell>

        <!-- ========== 问题与局限 ========== -->
        <mxCell id="problem_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="820" y="580" width="360" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="problem_title" value="&lt;b&gt;双线性插值的局限性&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="905" y="595" width="170" height="30" as="geometry"/>
        </mxCell>

        <!-- 问题1 -->
        <mxCell id="p1_icon" value="⚠️" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="840" y="640" width="40" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="p1_text" value="&lt;b&gt;拉链伪影&lt;/b&gt;（Zipper Artifact）&lt;br&gt;跨越物体边缘插值时，边缘两侧&lt;br&gt;像素混合，产生锯齿状条纹" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="632" width="260" height="55" as="geometry"/>
        </mxCell>

        <!-- 问题2 -->
        <mxCell id="p2_icon" value="⚠️" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="840" y="710" width="40" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="p2_text" value="&lt;b&gt;伪色&lt;/b&gt;（False Color）&lt;br&gt;高频纹理区域不同通道采样不同步，&lt;br&gt;重建后出现不存在的彩色条纹" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="700" width="280" height="55" as="geometry"/>
        </mxCell>

        <!-- 问题3 -->
        <mxCell id="p3_icon" value="⚠️" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="840" y="780" width="40" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="p3_text" value="&lt;b&gt;模糊&lt;/b&gt;（Blurring）&lt;br&gt;取均值操作本质是低通滤波，&lt;br&gt;抹平了高频细节，导致画面不锐利" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="770" width="280" height="55" as="geometry"/>
        </mxCell>

        <!-- 底部总结 -->
        <mxCell id="p_summary" value="&lt;font color=&quot;#888888&quot;&gt;这些问题促使了更高级算法的出现：&lt;br&gt;边缘自适应插值、AHD、VNG、LMMSE 等&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="875" y="845" width="260" height="40" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
