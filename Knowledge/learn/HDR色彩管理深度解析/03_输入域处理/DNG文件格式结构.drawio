<mxfile host="app.diagrams.net" modified="2026-03-21T10:00:00.000Z" agent="draw.io" version="21.0.0">
  <diagram name="DNG文件格式结构" id="dng-file-structure">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title" value="DNG (Digital Negative) 文件格式结构" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="400" height="40" as="geometry" />
        </mxCell>
        
        <!-- 左侧标题 -->
        <mxCell id="left-title" value="物理结构（文件布局）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="200" height="30" as="geometry" />
        </mxCell>
        
        <!-- 右侧标题 -->
        <mxCell id="right-title" value="关键元数据标签" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="200" height="30" as="geometry" />
        </mxCell>
        
        <!-- ==================== 左侧物理结构 ==================== -->
        
        <!-- 1. TIFF Header - 浅蓝色 -->
        <mxCell id="tiff-header" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="tiff-header-title" value="TIFF Header" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="115" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="tiff-header-content" value="• 字节序：II (Little Endian) / MM (Big Endian)&#xa;• 魔数：42 (0x002A)&#xa;• 第一个 IFD 偏移量" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="140" width="260" height="60" as="geometry" />
        </mxCell>
        
        <!-- 2. IFD0 - 浅绿色 -->
        <mxCell id="ifd0" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ifd0-title" value="IFD0 - 主图像描述" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="225" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ifd0-content" value="• 图像尺寸 (ImageWidth/ImageLength)&#xa;• 位深：10-bit / 12-bit / 14-bit&#xa;• CFA Pattern：RGGB / BGGR / GRBG / GBRG&#xa;• 色彩矩阵引用" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="250" width="260" height="80" as="geometry" />
        </mxCell>
        
        <!-- 3. SubIFD - 浅黄色 -->
        <mxCell id="subifd" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="subifd-title" value="SubIFD - 预览图（可选）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="355" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="subifd-content" value="• 缩略图 (JPEG Thumbnail)&#xa;• 预览图 (Preview Image)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="380" width="260" height="50" as="geometry" />
        </mxCell>
        
        <!-- 4. DNG私有标签区 - 浅紫色 -->
        <mxCell id="dng-private" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="dng-private-title" value="DNG 私有标签区" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="455" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="dng-private-content" value="• DNG 版本信息&#xa;• 相机校准数据&#xa;• 白平衡参数" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="480" width="260" height="60" as="geometry" />
        </mxCell>
        
        <!-- 5. 图像数据区 - 浅橙色 -->
        <mxCell id="image-data" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="image-data-title" value="图像数据区" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="565" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="image-data-content" value="• RAW 像素数据&#xa;• 压缩方式：未压缩 / 无损压缩 / 有损压缩&#xa;• Strip 或 Tile 存储" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="590" width="260" height="60" as="geometry" />
        </mxCell>
        
        <!-- ==================== 右侧元数据标签 ==================== -->
        
        <!-- 基础信息标签 -->
        <mxCell id="basic-tags" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="110" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="basic-tags-title" value="基础信息标签 (Tag 50706-50708)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="480" y="115" width="320" height="25" as="geometry" />
        </mxCell>
        <mxCell id="basic-tags-content" value="&lt;b&gt;DNGVersion&lt;/b&gt; (50706)&#xa;    DNG 规范版本号&#xa;&lt;b&gt;DNGBackwardVersion&lt;/b&gt; (50707)&#xa;    最低兼容版本&#xa;&lt;b&gt;UniqueCameraModel&lt;/b&gt; (50708)&#xa;    相机型号标识" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="490" y="145" width="300" height="90" as="geometry" />
        </mxCell>
        
        <!-- 传感器校准标签 -->
        <mxCell id="sensor-tags" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="260" width="320" height="130" as="geometry" />
        </mxCell>
        <mxCell id="sensor-tags-title" value="传感器校准标签 (Tag 50717-50719)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="480" y="265" width="320" height="25" as="geometry" />
        </mxCell>
        <mxCell id="sensor-tags-content" value="&lt;b&gt;BlackLevel&lt;/b&gt; (50717)&#xa;    传感器黑电平值&#xa;&lt;b&gt;WhiteLevel&lt;/b&gt; (50718)&#xa;    传感器饱和值（最大有效值）&#xa;&lt;b&gt;DefaultScale&lt;/b&gt; (50719)&#xa;    默认缩放比例" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="490" y="295" width="300" height="90" as="geometry" />
        </mxCell>
        
        <!-- 色彩校准标签 -->
        <mxCell id="color-tags" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="410" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="color-tags-title" value="色彩校准标签 (Tag 50778-50794)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="480" y="415" width="320" height="25" as="geometry" />
        </mxCell>
        <mxCell id="color-tags-content" value="&lt;b&gt;CalibrationIlluminant1&lt;/b&gt; (50778)&#xa;    校准光源1（如 D65 日光）&#xa;&lt;b&gt;CalibrationIlluminant2&lt;/b&gt; (50779)&#xa;    校准光源2（如 A 钨丝灯）&#xa;&lt;b&gt;ColorMatrix1&lt;/b&gt; (50781)&#xa;    光源1下的色彩矩阵 (3×3)&#xa;&lt;b&gt;ColorMatrix2&lt;/b&gt; (50782)&#xa;    光源2下的色彩矩阵 (3×3)&#xa;&lt;b&gt;AsShotWhiteXY&lt;/b&gt; (50794)&#xa;    拍摄时的白点色度坐标" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="490" y="445" width="300" height="160" as="geometry" />
        </mxCell>
        
        <!-- ==================== 连接箭头 ==================== -->
        
        <!-- TIFF Header 指向 IFD0 的偏移量指针 -->
        <mxCell id="arrow-header-ifd0" value="偏移量指针" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6c8ebf;endArrow=classic;endFill=1;fontSize=11;" edge="1" parent="1" source="tiff-header" target="ifd0">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="20" y="160" />
              <mxPoint x="20" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- IFD0 指向 基础信息标签 -->
        <mxCell id="arrow-ifd0-basic" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="ifd0" target="basic-tags">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="250" />
              <mxPoint x="400" y="175" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- IFD0 指向 传感器校准标签 -->
        <mxCell id="arrow-ifd0-sensor" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="ifd0" target="sensor-tags">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="310" />
              <mxPoint x="400" y="325" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- DNG私有标签区 指向 色彩校准标签 -->
        <mxCell id="arrow-private-color" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#9673a6;endArrow=classic;endFill=1;dashed=1;" edge="1" parent="1" source="dng-private" target="color-tags">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="500" />
              <mxPoint x="400" y="510" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- ==================== 图例 ==================== -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;strokeWidth=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="630" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="图例：实线箭头 = 偏移量指针 | 虚线箭头 = 标签引用" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="480" y="640" width="320" height="20" as="geometry" />
        </mxCell>
        
      </root>
    </mxGraphModel>
