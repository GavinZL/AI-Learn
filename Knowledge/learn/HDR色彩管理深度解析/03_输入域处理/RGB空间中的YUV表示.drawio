        </mxCell>
        
        <!-- ==================== 右侧说明区 ==================== -->
        <!-- YUV 转换公式 -->
        <mxCell id="formula_box" value="" style="rounded=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="formula_title" value="YUV 转换公式" style="text;fontSize=15;fontStyle=1;fontColor=#333333;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="148" width="280" height="22" as="geometry" />
        </mxCell>
        <mxCell id="formula_content" value="Y = 0.299R + 0.587G + 0.114B&#xa;U = B - Y（蓝色差）&#xa;V = R - Y（红色差）" style="text;fontSize=13;fontColor=#333333;align=left;spacingLeft=15;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="730" y="175" width="260" height="75" as="geometry" />
        </mxCell>
        
        <!-- 几何含义 -->
        <mxCell id="geo_box" value="" style="rounded=1;fillColor=#FFFDE7;strokeColor=#FFD54F;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="280" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="geo_title" value="几何含义" style="text;fontSize=15;fontStyle=1;fontColor=#F57F17;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="288" width="280" height="22" as="geometry" />
        </mxCell>
        <mxCell id="geo_content" value="• Y：沿主对角线的投影（亮度分量）&#xa;&#xa;• U/V：垂直于主对角线的平面上&#xa;       的坐标（色度分量）&#xa;&#xa;• 同一 Y 值的所有颜色位于&#xa;  同一色度平面上" style="text;fontSize=12;fontColor=#5D4037;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="725" y="312" width="265" height="105" as="geometry" />
        </mxCell>
        
        <!-- 设计意义 -->
        <mxCell id="design_box" value="" style="rounded=1;fillColor=#E8F5E9;strokeColor=#81C784;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="440" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="design_title" value="设计意义" style="text;fontSize=15;fontStyle=1;fontColor=#2E7D32;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="448" width="280" height="22" as="geometry" />
        </mxCell>
        <mxCell id="design_content" value="• 人眼对亮度（Y）更敏感&#xa;&#xa;• 色度（U/V）可大幅压缩&#xa;&#xa;• 这就是 YUV 4:2:0 采样的&#xa;  理论基础" style="text;fontSize=12;fontColor=#1B5E20;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="725" y="475" width="265" height="90" as="geometry" />
        </mxCell>
        
        <!-- ==================== 图表标题 ==================== -->
