        <mxCell id="uvPlane" value="" style="shape=polygon;fillColor=#E6E6FA;fillOpacity=50;strokeColor=#9370DB;strokeWidth=2;points=[[0.5,0],[1,0.5],[0.5,1],[0,0.5]];" vertex="1" parent="1">
